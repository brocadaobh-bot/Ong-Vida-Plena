# ============================================================
# Variáveis de Ambiente — Vida Plena
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLE_AQUI_SUA_CHAVE_PUBLICA

# Service Role — NUNCA exponha no client / browser
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_SUA_SERVICE_ROLE_KEY

# URL base da aplicação (deve bater com Site URL no Supabase Auth)
# Dev: http://localhost:3001 | Produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Administradores protegidos (separados por vírgula)
PROTECTED_ADMIN_EMAILS=seu@email.com
